{
  "manifest_version": 3,
  "name": "Kubiks Network Logger",
  "version": "1.0.0",
  "description": "Capture Chrome history and network activity for Kubiks observability",
  "permissions": [
    "history",
    "webRequest",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Kubiks Logger"
  }
}
