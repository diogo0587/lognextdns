{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "hugo",
  "installCommand": "cd painel && git submodule update --init --recursive || true",
  "buildCommand": "cd painel && hugo --gc --minify --destination public",
  "outputDirectory": "painel/public",
  "build": {
    "env": {
      "HUGO_VERSION": "0.124.1"
    }
  }
}
